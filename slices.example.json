{
  "port": 3000,
  "dotenv": true,
  "cors": true,
  "mongoDB": true,
  "bodyParser": {
    "json": true,
    "urlencoded": { "extended": true }
  },
  "routes": {
    "/health": {
      "GET": { "type": "template", "template": "health" }
    },
    "/auth/sign-up": {
      "POST": { "type": "template", "template": "signUp" }
    },
    "/auth/sign-in": {
      "POST": { "type": "template", "template": "signIn" }
    },
    "/items/:collection": {
      "GET": { "type": "template", "template": "listItems" },
      "POST": {
        "type": "template",
        "template": "listItems",
        "middleware": ["requireAuth"]
      }
    },
    "/items/:collection/:id": {
      "GET": { "type": "template", "template": "listItems" },
      "PUT": { "type": "template", "template": "listItems", "middleware": ["requireAuth"] },
      "DELETE": { "type": "template", "template": "listItems", "middleware": ["requireAuth"] }
    },
    "/db/:collection": {
      "GET": { "type": "template", "template": "mongoItems" },
      "POST": { "type": "template", "template": "mongoItems", "middleware": ["requireAuth"] }
    },
    "/db/:collection/:id": {
      "GET": { "type": "template", "template": "mongoItems" },
      "PUT": { "type": "template", "template": "mongoItems", "middleware": ["requireAuth"] },
      "DELETE": { "type": "template", "template": "mongoItems", "middleware": ["requireAuth"] }
    }
  },
  "websockets": {
    "/ws": { "template": "echo" }
  }
}
