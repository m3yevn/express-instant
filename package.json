{
  "name": "express-instant",
  "version": "1.3.0",
  "description": "Instant Express — JSON-configured Express server with auth, CRUD templates, WebSockets, and custom handlers.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "express-instant": "./bin/express-instant.js"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/express-instant.js --config-file example/server.json",
    "dev": "nodemon bin/express-instant.js --config-file example/server.json",
    "test": "node --test --test-concurrency=1 test/integration.test.js test/openapi.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/m3yevn/express-instant.git"
  },
  "homepage": "https://express-instant.vercel.app",
  "bugs": {
    "url": "https://github.com/m3yevn/express-instant/issues"
  },
  "keywords": [
    "instant-express",
    "express-instant",
    "json-config",
    "low-code-api",
    "express",
    "rest-api",
    "jwt-auth",
    "mongodb",
    "websocket",
    "nodejs"
  ],
  "author": "Kevin Moe Myint Myat <m3.luvusomuch@gmail.com> (https://kevinmoemyintmyat.vercel.app)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.7"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.9.0",
    "ws": "^8.18.0"
  }
}
