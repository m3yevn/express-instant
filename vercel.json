{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/vercel.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/docs",
      "dest": "/public/docs.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
